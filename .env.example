# =====================================================
# Common Home Server Environment Variables
# =====================================================

TIME_ZONE=Asia/Krasnoyarsk
BACKUP_BASE=/mnt/media/volume-b/backup

# =====================================================
# Traefik
# =====================================================
DOMAIN=yourdomain.com
TRAEFIK_DASHBOARD_PORT=8080  # Доступ в локальной сети (НЕ пробрасывать на роутере!)

# Сгенерировать пароль:
# echo $(htpasswd -nb admin your-password) | sed -e s/\\$/\\$\\$/g
# Или онлайн: https://hostingcanada.org/htpasswd-generator/
# По умолчанию: admin / changeme
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$8kOQFgh2$$LhxXpEtBWEGWvZREjQK2M.

# =====================================================
# MairaDb
# =====================================================
MYSQL_ROOT_PASSWORD=db-root-password
MYSQL_DATA=./volumes/mysql_data

# =====================================================
# Redis
# =====================================================
REDIS_PASSWORD=redis-password

# -----------------------------------------------------
# Seafile - Облачное хранилище
# -----------------------------------------------------
SEAFILE_VOLUME=./mnt/media/volume-a/seafile
SEAFILE_MYSQL_DB_PASSWORD=db-seafile-password
SEAFILE_INIT_ADMIN_EMAIL=admin@yourdomain.com
SEAFILE_SERVER_HOSTNAME=files.yourdomain.com
SEAFILE_JWT_PRIVATE_KEY=jwt-key
SEAFILE_INIT_ADMIN_PASSWORD=init-admin-password


# -----------------------------------------------------
# Navidrome - Музыкальный стриминг-сервер
# -----------------------------------------------------
NAVIDROME_DOMAIN=music.yourdomain.com
# Путь к музыкальной библиотеке на хосте (измените на свой!)
NAVIDROME_MUSIC_PATH=/path/to/your/music
NAVIDROME_VOLUME=./volumes/navidrome/data

# -----------------------------------------------------
# qBittorrent - Торрент-клиент
# -----------------------------------------------------
# Путь для загрузок на хосте (измените на свой!)

# Примечание: порт 6881 для торрентов нужно пробросить на роутере (TCP+UDP)
QBITTORRENT_LOCAL_PORT=8082
QBITTORRENT_DOWNLOADS_PATH=/path/to/downloads
